# sfdc-mcp-server environment variables. Copy to .env and fill in what you need —
# or set these in your MCP client's config (the `env` block in
# claude_desktop_config.json, or `claude mcp add ... -e VAR=value`).
#
# Defaults shown are what the server uses when a variable is unset
# (see src/sfdc_mcp/settings.py).

# Auth mode: device_code (interactive — a human signs in via browser) or
# client_credentials (unattended — see the README's warning: it sees everything the
# app's run-as user is granted, no per-caller access control).
#SFDC_MCP_AUTH=device_code

# Connected/External Client App's consumer key. Required for both auth modes.
#SFDC_MCP_CLIENT_ID=

# SECRET. Consumer secret from the app's OAuth settings. Required for
# client_credentials only; leave unset for device_code (a public client).
#SFDC_MCP_CLIENT_SECRET=

# OAuth login endpoint. The default works for device_code against a production org;
# sandboxes use https://test.salesforce.com. client_credentials requires a My Domain
# URL instead of either (e.g. https://your-domain.my.salesforce.com) — find yours
# under Setup -> My Domain.
#SFDC_MCP_LOGIN_URL=https://login.salesforce.com

# Salesforce REST API version.
#SFDC_MCP_API_VERSION=62.0

# Default max records/results returned per call before "showing N of M" is reported.
#SFDC_MCP_ITEM_LIMIT=25

# HTTP timeout (seconds) per Salesforce request.
#SFDC_MCP_TIMEOUT_SECONDS=30.0

# Where the device-code token cache is persisted (holds a refresh token; written
# at mode 600).
#SFDC_MCP_TOKEN_CACHE_PATH=~/.sfdc-mcp/token_cache.json
